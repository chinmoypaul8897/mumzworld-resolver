# Mumzworld Resolver — required environment variables.
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`. It is gitignored.

# OpenRouter API key — primary LLM at runtime.
# Free tier is sufficient. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# OpenAI API key — used ONLY for evaluation (LLM-as-judge).
# Optional. We use $5 of credit on gpt-4o-mini for arabic eval.
OPENAI_API_KEY=sk-...